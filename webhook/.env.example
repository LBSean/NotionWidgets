# Notion Integration Token (starts with ntn_ or secret_)
# Get yours at: https://www.notion.so/my-integrations
NOTION_TOKEN=ntn_your_token_here

# Database IDs (32-character hex strings from Notion URLs)
# Run "npm run setup" to create these automatically.
NOTION_DB_ID=your_pomodoro_database_id
NOTION_HABITS_DB_ID=your_habits_database_id
NOTION_WIDGET_DATA_DB_ID=your_widget_data_database_id
NOTION_STICKY_DB_ID=your_sticky_notes_database_id
